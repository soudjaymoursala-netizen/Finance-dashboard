# .env.example

# Option A - Utiliser le Cloudflare Worker (recommandé si vos sheets ne sont pas publiques)
# Déployez le worker et mettez ici son URL (ex: https://mon-worker.workers.dev)
# Le Worker doit avoir ces secrets (SHEET_BUDGET, SHEET_CTO, SHEET_PEA, SHEET_EVOLUTION, SHEET_OBJECTIF)
# et ALLOWED_ORIGIN doit être la valeur exacte de votre site (ex: https://soudjaymoursala-netizen.github.io)
PROXY_BASE_URL=https://your-worker-id.workers.dev

# Option B - Ne pas utiliser de Worker : fournir directement les URLs publiques CSV des Google Sheets
VITE_URL_BUDGET=https://docs.google.com/spreadsheets/d/YOUR_ID/export?format=csv&gid=...
VITE_URL_CTO=https://docs.google.com/spreadsheets/d/YOUR_ID/export?format=csv&gid=...
VITE_URL_PEA=https://docs.google.com/spreadsheets/d/YOUR_ID/export?format=csv&gid=...
VITE_URL_EVOLUTION=https://docs.google.com/spreadsheets/d/YOUR_ID/export?format=csv&gid=...
VITE_URL_OBJECTIF=https://docs.google.com/spreadsheets/d/YOUR_ID/export?format=csv&gid=...
